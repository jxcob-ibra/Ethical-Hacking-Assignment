# Database Configuration
DB_HOST=mysql
DB_NAME=myeduconnect
DB_USER=root
DB_PASS=rootpassword
DB_CHARSET=utf8mb4

# Application Configuration
APP_NAME=MyEduConnect
APP_URL=http://localhost:8080
APP_VERSION=2.0.0

# Security Configuration
SESSION_NAME=myeduconnect_session
SESSION_LIFETIME=3600
CSRF_TOKEN_NAME=csrf_token
PASSWORD_MIN_LENGTH=8

# File Upload Configuration
UPLOAD_DIR=/var/www/html/app/uploads/
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=pdf,doc,docx,ppt,pptx,txt,zip

# Security Mode (GLOBAL)
# vulnerable = All attacks enabled
# secure = All attacks disabled
SECURITY_MODE=secure

# Individual Vulnerability Toggles
SQLI_ENABLED=false
XSS_ENABLED=false
IDOR_ENABLED=false
UPLOAD_ENABLED=false
WEAK_AUTH_ENABLED=false
CSRF_ENABLED=false
EXPOSED_DATABASE_ENABLED=false

# Email Configuration (for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@myeduconnect.com
SMTP_FROM_NAME=MyEduConnect

# Pagination
ITEMS_PER_PAGE=10

# Timezone
TIMEZONE=UTC

# Error Reporting (Set to 0 in production)
ERROR_REPORTING=1
DISPLAY_ERRORS=1
